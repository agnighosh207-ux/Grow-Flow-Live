# ══════════════════════════════════════════════════════
# GrowFlow AI — Environment Variables
# Copy to .env and fill in your values
# NEVER commit .env to git
# ══════════════════════════════════════════════════════

# ── SERVER ─────────────────────────────────────────────
NODE_ENV=production
APP_STATUS=PRODUCTION
ALLOWED_ORIGINS=https://growflowai.space,https://www.growflowai.space
ADMIN_EMAIL=your-admin-email@gmail.com

# ── AI — OpenRouter (Perplexity + Gemini via one key) ──
# Get key at: https://openrouter.ai/keys
# Add credits at: https://openrouter.ai/credits
# Models: perplexity/sonar (web search) + google/gemini-flash-1.5 (writing)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxx

# ── AI — Groq (Fallback only) ───────────────────────────
# Get key at: https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx
GROQ_API_KEY_SECONDARY=gsk_xxxxxxxxxxxxxxxxxxxx

# ── DATABASE ────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── AUTH — Clerk ────────────────────────────────────────
CLERK_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
CLERK_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx
VITE_CLERK_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx

# ── PAYMENTS — Razorpay ────────────────────────────────
RAZORPAY_LIVE_KEY_ID=rzp_live_xxxxxxxxxxxxxxxxxxxx
RAZORPAY_LIVE_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxx
VITE_RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxxxxxxxx

# Razorpay Subscription Plan IDs (create in Razorpay Dashboard)
RAZORPAY_PLAN_STARTER_MONTHLY=plan_xxxxxxxxxxxxxxxxxxxx
RAZORPAY_PLAN_STARTER_QUARTERLY=plan_xxxxxxxxxxxxxxxxxxxx
RAZORPAY_PLAN_STARTER_HALFYEARLY=plan_xxxxxxxxxxxxxxxxxxxx
RAZORPAY_PLAN_STARTER_YEARLY=plan_xxxxxxxxxxxxxxxxxxxx

RAZORPAY_PLAN_CREATOR_MONTHLY=plan_xxxxxxxxxxxxxxxxxxxx
RAZORPAY_PLAN_CREATOR_QUARTERLY=plan_xxxxxxxxxxxxxxxxxxxx
RAZORPAY_PLAN_CREATOR_HALFYEARLY=plan_xxxxxxxxxxxxxxxxxxxx
RAZORPAY_PLAN_CREATOR_YEARLY=plan_xxxxxxxxxxxxxxxxxxxx

RAZORPAY_PLAN_INFINITY_MONTHLY=plan_xxxxxxxxxxxxxxxxxxxx
RAZORPAY_PLAN_INFINITY_QUARTERLY=plan_xxxxxxxxxxxxxxxxxxxx
RAZORPAY_PLAN_INFINITY_HALFYEARLY=plan_xxxxxxxxxxxxxxxxxxxx
RAZORPAY_PLAN_INFINITY_YEARLY=plan_xxxxxxxxxxxxxxxxxxxx

RAZORPAY_PLAN_AGENCY_MONTHLY=plan_xxxxxxxxxxxxxxxxxxxx
RAZORPAY_PLAN_AGENCY_YEARLY=plan_xxxxxxxxxxxxxxxxxxxx

# Credit Top-Up (one-time orders, not subscriptions)
RAZORPAY_TOPUP_SMALL_CREDITS=10
RAZORPAY_TOPUP_SMALL_AMOUNT=4900
RAZORPAY_TOPUP_MEDIUM_CREDITS=25
RAZORPAY_TOPUP_MEDIUM_AMOUNT=9900
RAZORPAY_TOPUP_LARGE_CREDITS=60
RAZORPAY_TOPUP_LARGE_AMOUNT=19900

# ── EMAIL — Resend ──────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# ── MONITORING — Sentry (optional) ─────────────────────
SENTRY_DSN=
VITE_SENTRY_DSN=
