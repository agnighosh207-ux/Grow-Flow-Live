# ============================================================
# GrowFlow AI — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit your .env file to git
# ============================================================

# ------------------------------------------------------------
# SERVER
# ------------------------------------------------------------
PORT=3000
NODE_ENV=development

# ------------------------------------------------------------
# AI — Groq API (RECOMMENDED - Fast & Affordable)
# Get your key at: https://console.groq.com/keys
# Set USE_GROQ_API=true to enable Groq
# Models: llama-3.1-8b-instant (fast), llama-3.3-70b-versatile (complex)
# ------------------------------------------------------------
USE_GROQ_API=true
GROQ_API_KEY=gsk_...
GROQ_API_KEY_SECONDARY=gsk_...
CEREBRAS_API_KEY=csk_...
GEMINI_API_KEY=...
OPENROUTER_API_KEY=sk-...
TOGETHER_AI_API_KEY=tgp_v1_...
SAMBANOVA_API_KEY=...

# Optional: Only use if not using Groq
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://your-proxy.com/v1

# ------------------------------------------------------------
# DATABASE — PostgreSQL (REQUIRED)
# Format: postgresql://user:password@host:5432/dbname
# Free options: Neon (neon.tech), Supabase, Railway
# ------------------------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/growflow

# ------------------------------------------------------------
# AUTH — Clerk (REQUIRED)
# Get keys at: https://dashboard.clerk.com
# ------------------------------------------------------------
CLERK_SECRET_KEY=sk_...
CLERK_PUBLISHABLE_KEY=pk_...
VITE_CLERK_PUBLISHABLE_KEY=pk_...

# ------------------------------------------------------------
# PAYMENTS — Razorpay (REQUIRED for paid plans)
# Get keys at: https://dashboard.razorpay.com/app/keys
# ------------------------------------------------------------
RAZORPAY_KEY_ID=rzp_...
RAZORPAY_KEY_SECRET=...
RAZORPAY_WEBHOOK_SECRET=...
VITE_RAZORPAY_KEY_ID=rzp_...
RAZORPAY_PLAN_STARTER=plan_test_xyz1
RAZORPAY_PLAN_CREATOR=plan_test_xyz2
RAZORPAY_PLAN_INFINITY=plan_test_xyz3

# ------------------------------------------------------------
# FRONTEND (Vite)
# ------------------------------------------------------------
BASE_PATH=/

# ------------------------------------------------------------
# SUPABASE
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_...

# ------------------------------------------------------------
# EMAIL — Resend
# ------------------------------------------------------------
RESEND_API_KEY=re_...

# ------------------------------------------------------------
# MONITORING — Sentry
# ------------------------------------------------------------
SENTRY_DSN=
VITE_SENTRY_DSN=

# ------------------------------------------------------------
# PRODUCTION SANITY CHECK
# 1. CLERK_SECRET_KEY: Use 'sk_live_...' for Production.
# 2. VITE_CLERK_PUBLISHABLE_KEY: Use 'pk_live_...' for Production.
# 3. RAZORPAY_KEY_ID: Must be your 'rzp_live_...' key for Production.
# 4. API_URL / VITE_API_URL: Set to 'api.growflowai.space' instead of localhost for the Frontend build.
# 5. GROQ_API_KEY: Should be a Paid tier key for high-limit traffic.
# ------------------------------------------------------------
