# ══════════════════════════════════════════════════════
# GrowFlow AI — Environment Variables
# Copy to .env and fill in your values
# NEVER commit .env to git
# ══════════════════════════════════════════════════════

# ── SERVER ─────────────────────────────────────────────
NODE_ENV=production
APP_STATUS=LIVE
ALLOWED_ORIGINS=https://growflowai.space,https://www.growflowai.space
ADMIN_EMAIL=your-admin-email@gmail.com

# ── AI — AI PROVIDERS ───────────────────────────
# Get keys at: https://openrouter.ai/keys | https://console.groq.com/keys
# OPENAI_API_KEY — Not used. All AI runs via OpenRouter (Perplexity+Gemini) and Groq.
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx
GROQ_API_KEY_SECONDARY=gsk_xxxxxxxxxxxxxxxxxxxx
PERPLEXITY_AI_API=sk-or-v1-xxxxxxxxxxxxxxxxxxxx
TOGETHER_AI_API_KEY=tgp_v1_xxxxxxxxxxxxxxxxxxxx
CEREBRAS_API_KEY=csk-xxxxxxxxxxxxxxxxxxxx
SAMBANOVA_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
GEMINI_API_KEY=xxxxxxxxxxxxxxxxxxxx

# Override Gemini model if needed (check openrouter.ai/models for latest)
# GEMINI_MODEL_OVERRIDE=google/gemini-flash-1.5

# ── DATABASE ────────────────────────────────────────────
# Format: postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://xxxxxxxxxxxxxxxxxxxx

# ── AUTH — Clerk ────────────────────────────────────────
# Get keys at: https://dashboard.clerk.com (Production Instance)
CLERK_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
CLERK_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx
VITE_CLERK_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx

# ── PAYMENTS — Razorpay ────────────────────────────────
# Get keys at: https://dashboard.razorpay.com/app/keys (Live Mode)
RAZORPAY_LIVE_KEY_ID=rzp_live_xxxxxxxxxxxxxxxxxxxx
RAZORPAY_LIVE_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx
# Razorpay Webhook (configure this URL in Razorpay Dashboard)
# Go to: dashboard.razorpay.com → Settings → Webhooks → Add Webhook
# Webhook URL must be: https://growflowai.space/api/subscription/webhook
# Events to enable: subscription.activated, subscription.charged,
#   subscription.halted, subscription.cancelled, subscription.expired, 
#   subscription.updated, payment.failed
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here
# The webhook URL is always: https://[your-domain]/api/subscription/webhook
# No code change needed — it is already wired in the backend
VITE_RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxxxxxxxx

# Razorpay Subscription Plan IDs
RAZORPAY_PLAN_STARTER_MONTHLY=plan_xxxxxxxxxxxxxxxxxxxx
RAZORPAY_PLAN_CREATOR_MONTHLY=plan_xxxxxxxxxxxxxxxxxxxx
RAZORPAY_PLAN_INFINITY_MONTHLY=plan_xxxxxxxxxxxxxxxxxxxx
RAZORPAY_PLAN_AGENCY_MONTHLY=plan_xxxxxxxxxxxxxxxxxxxx
RAZORPAY_PLAN_AGENCY_YEARLY=plan_xxxxxxxxxxxxxxxxxxxx

# ── EMAIL — Resend ──────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# ── MONITORING — Sentry (optional) ─────────────────────
SENTRY_DSN=
VITE_SENTRY_DSN=
