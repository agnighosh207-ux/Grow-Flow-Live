{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter @workspace/api-server --filter @workspace/content-engine run dev",
    "dev:api": "pnpm --filter @workspace/api-server run dev",
    "dev:frontend": "pnpm --filter @workspace/content-engine run dev",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "start": "pnpm --filter @workspace/api-server run start",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter ./frontend --filter ./backend --filter ./sandbox --filter ./scripts --if-present run typecheck",
    "db:push": "pnpm --filter @workspace/db run push",
    "db:studio": "pnpm --filter @workspace/db run studio"
  },
  "private": true,
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "cross-env": "^7.0.3",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  },
  "dependencies": {
    "react": "catalog:",
    "react-dom": "catalog:",
    "stripe": "^22.0.0"
  }
}
